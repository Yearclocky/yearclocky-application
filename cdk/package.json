{
  "name": "yearclocky-cdk",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Reusable AWS CDK construct for the Yearclocky application.",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "lambda/**/*",
    "lib/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cdk": "cdk",
    "clean": "rm -rf cdk.out dist",
    "synth": "cdk synth",
    "watch": "tsc -w -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.190.0",
    "constructs": "^10.4.2"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1019.0",
    "@aws-sdk/lib-dynamodb": "^3.1019.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "aws-cdk": "^2.190.0",
    "aws-cdk-lib": "^2.190.0",
    "constructs": "^10.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
